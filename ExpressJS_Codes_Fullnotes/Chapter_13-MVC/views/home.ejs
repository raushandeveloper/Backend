<%- include ('partials/head') %>
<body>
  <%- include ('partials/nav') %>

  <main class="mx-auto px-6 mt-10 max-w-7xl" style="width:100%; display: flex; flex-direction: column; align-items: center;">
    
    <h2 class="text-3xl text-red-500 font-bold text-center mb-8">
      Here are our registered homes:
    </h2>

    <!-- GRID FIX -->
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" style="width:50rem; display:grid; flex-wrap: wrap; justify-content: center;">
      
      <% registeredHomes.forEach(home => { %>
        
        <!-- CARD -->
        <li class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden hover:shadow-lg transition duration-300">

          <!-- IMAGE -->
          <img 
            src="<%= home.photoUrl %>" 
            alt="<%= home.houseName %>"
            class="w-full h-48 object-cover"
          />

          <!-- CONTENT -->
          <div class="p-4">
            
            <!-- TITLE + RATING -->
            <div class="flex justify-between items-start mb-2">
              <h3 class="text-lg font-semibold text-gray-800 truncate">
                <%= home.houseName %>
              </h3>

              <span class="flex items-center gap-1 bg-green-100 text-green-700 text-sm px-2 py-1 rounded-md">
                ⭐ <%= home.rating %>
              </span>
            </div>

            <!-- LOCATION -->
            <p class="text-sm text-gray-500 mb-3">
              📍 <%= home.location %>
            </p>

            <!-- PRICE + BUTTON -->
            <div class="flex justify-between items-center border-t pt-3">
              <div>
                <p class="text-xs text-gray-400">Per night</p>
                <p class="text-lg font-bold text-gray-900">
                  ₹<%= home.price %>
                </p>
              </div>

              <a href="#" class="bg-red-500 hover:bg-red-600 text-white text-sm px-4 py-2 rounded-lg transition">
                Book
              </a>
            </div>

          </div>

        </li>

      <% }) %>

    </ul>

  </main>
</body>
</html>