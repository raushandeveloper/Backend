<%- include ('partials/head') %>
<body>
   <%- include ('partials/nav') %>
    <main class="container mx-auto bg-white shadow-lg p-8 mt-10 max-w-xl">
        <h1 class="text-3xl text-red-500 font-bold text-center mb-6">
            Register Your Home on AirBnB</h1>
        <form action="/host/add-home" method="POST" class="space-y-4">
            <div>
                <input type="text" id="houseName" name="houseName" placeholder="Enter your House Name" required class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-red-500"><br>
                <input type="text" id="price" name="price" placeholder="Price Per Night" required class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-red-500"><br>
                <input type="text" id="Location" name="Location" placeholder="Enter Location" required class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-red-500"><br>
                <input type="text" id="Rating" name="Rating" placeholder="Rating:" required class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-red-500"><br>
                <input type="text" id="PhotoUrl" name="PhotoUrl" placeholder="PhotoUrl" required class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-red-500"><br>
            </div>
            <button type="submit" class="bg-red-500 text-white py-2 px-4 rounded hover:bg-red-400 transition duration-300">Add Home</button>
        </form>
</body>
</html>